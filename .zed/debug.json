[
  {
    "adapter": "JavaScript",
    "label": "Launch Brave",
    "type": "chrome",
    "request": "launch",
    "url": "http://localhost:3000",
    "webRoot": "$ZED_WORKTREE_ROOT/web",
    "runtimeExecutable": "/usr/bin/brave-browser"
  },
  {
    "request": "launch",
    "label": "Debug SiteServer",
    "program": "$ZED_WORKTREE_ROOT/.build/debug/SiteServer",
    "args": ["-h", "0.0.0.0"],
    "adapter": "Swift",
    "build": {
      "command": "swift",
      "args": ["build", "--product", "SiteServer"]
    }
  },
  {
    "adapter": "Swift",
    "request": "launch",
    "label": "Debug SiteSSHServer",
    "program": "$ZED_WORKTREE_ROOT/.build/debug/SiteSSHServer",
    "args": [],
    "build": {
      "command": "swift",
      "args": ["build", "--product", "SiteSSHServer"]
    }
  }
]
