    "nuxt": "^4.4.4",
    "tailwindcss": "^4.2.4",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@tsconfig/node24": "^24.0.4",
    "oxlint-tsgolint": "^0.22.1",
    "rolldown": "1.0.0-rc.18",
    "typescript": "~6.0.3",
